# ─── Chzzk-Recorder-Pro 환경 변수 템플릿 ───
# 이 파일을 복사하여 .env 파일을 생성하고 값을 채워 사용하세요.
# cp .env.example .env

# ── 앱 설정 ──────────────────────────────────────────────
DEBUG=false

# ── 서버 설정 ─────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── FFmpeg 경로 ───────────────────────────────────────────
# Docker: 자동 설치되므로 기본값(ffmpeg) 사용
# Windows .exe: 내장 바이너리 사용 (설정 불필요)
# Linux Native: ffmpeg가 PATH에 있으면 기본값 사용
FFMPEG_PATH=ffmpeg

# ── 녹화 저장 경로 ────────────────────────────────────────
DOWNLOAD_DIR=./recordings

# 분할 저장 경로 사용 여부 (true 시 아래 경로가 적용됨)
SPLIT_DOWNLOAD_DIRS=false
VOD_CHZZK_DIR=
VOD_EXTERNAL_DIR=

# ── 치지직 인증 쿠키 (성인 인증 / 1080p 접근용, 선택사항) ──
NID_AUT=
NID_SES=

# ── 감시 주기 (초, 기본: 30) ─────────────────────────────
MONITOR_INTERVAL=30

# ── 녹화 설정 ─────────────────────────────────────────────
OUTPUT_FORMAT=ts
RECORDING_QUALITY=best
MAX_RECORD_RETRIES=3

# ── VOD 다운로드 설정 ─────────────────────────────────────
VOD_MAX_CONCURRENT=3
VOD_DEFAULT_QUALITY=best
VOD_MAX_SPEED=0
KEEP_DOWNLOAD_PARTS=false

# ── 채팅 아카이빙 ─────────────────────────────────────────
CHAT_ARCHIVE_ENABLED=false

# ── Discord Bot (선택사항) ────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_NOTIFICATION_CHANNEL_ID=
