# ─── Chzzk-Recorder-Pro 환경 변수 ───

# 앱 설정
DEBUG=false

# FFmpeg 경로 (기본: C:\ffmpeg\bin\ffmpeg.exe)
FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe

# 녹화 저장 경로 (기본: ./recordings)
DOWNLOAD_DIR=./recordings

# 치지직 인증 쿠키 (성인 인증 / 1080p 접근용)
NID_AUT=
NID_SES=

# 서버 설정
HOST=0.0.0.0
PORT=8000

# 감시 주기 (초, 기본: 30)
MONITOR_INTERVAL=30

# Discord Bot 토큰 (Phase 2)
DISCORD_BOT_TOKEN=
